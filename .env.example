# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=MetaHRM Face Recognition Service
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ============================================
# MODEL CONFIGURATION
# ============================================
# Options: 'vggface2' or 'casia-webface'
# vggface2: Trained on 9131 people, 3.31M images (RECOMMENDED)
# casia-webface: Trained on 10K people, 500K images
FACENET_MODEL=vggface2

# MTCNN Face Detection
MTCNN_MIN_FACE_SIZE=20
MTCNN_THRESHOLDS=0.6,0.7,0.7
MTCNN_FACTOR=0.709

# ============================================
# RECOGNITION THRESHOLDS
# ============================================
# Euclidean distance: < threshold = same person
EUCLIDEAN_THRESHOLD=1.0

# Cosine similarity: > threshold = same person  
COSINE_THRESHOLD=0.6

# Minimum face detection confidence (0.0 - 1.0)
MIN_FACE_CONFIDENCE=0.95

# ============================================
# IMAGE PROCESSING
# ============================================
# Maximum upload size (bytes) - 10MB
MAX_IMAGE_SIZE=10485760

# Allowed extensions
ALLOWED_EXTENSIONS=jpg,jpeg,png

# Target face size for FaceNet (DO NOT CHANGE)
TARGET_FACE_SIZE=160

# Image quality
MIN_IMAGE_WIDTH=200
MIN_IMAGE_HEIGHT=200
MAX_IMAGE_WIDTH=4000
MAX_IMAGE_HEIGHT=4000

# ============================================
# ANOMALY DETECTION
# ============================================
# Minimum image quality score (0.0 - 1.0)
MIN_IMAGE_QUALITY_SCORE=0.7

# Maximum number of faces allowed in one image
MAX_FACES_ALLOWED=1

# Minimum face area ratio (face_area / image_area)
MIN_FACE_AREA_RATIO=0.05

# ============================================
# CORS
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/face_service.log